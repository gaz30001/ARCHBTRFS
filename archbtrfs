#!/bin/bash
set -e
clear

# Цвета
GREEN="\e[32m"
RED="\e[31m"
YELLOW="\e[33m"
RESET="\e[0m"

echo -e "${YELLOW}Arch Linux Installer - Final Stable Version${RESET}"

# Проверка интернета
ping -q -c 1 archlinux.org > /dev/null || { echo -e "${RED}No internet${RESET}"; exit 1; }
timedatectl set-ntp true

# Параметры (подставь свои, если нужно)
DISK="/dev/sda"
HOSTNAME="archlinux"
USERNAME="oleg"

# Очистка перед началом (чтобы не было ошибки "mounted filesystem")
umount -R /mnt 2>/dev/null || true
swapoff -a 2>/dev/null || true

# Разметка
sgdisk --zap-all $DISK
sgdisk -n 1:0:+550M -t 1:ef00 $DISK
sgdisk -n 2:0:0 -t 2:8300 $DISK
PART_EFI="${DISK}1"
PART_ROOT="${DISK}2"

# Форматирование
mkfs.fat -F32 $PART_EFI
mkfs.btrfs -f -L ArchLinux $PART_ROOT
mount $PART_ROOT /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
umount /mnt

# Монтирование
mount -t btrfs -o subvol=@,compress=zstd:2,ssd $PART_ROOT /mnt
mkdir -p /mnt/{boot,home}
mount -t btrfs -o subvol=@home,compress=zstd:2,ssd $PART_ROOT /mnt/home
mount $PART_EFI /mnt/boot

# Обновление зеркал (упрощено для надежности)
echo -e "\n${GREEN}Updating package databases...${RESET}"
pacman -Sy --noconfirm

# Установка системы (БЕЗ nvidia, чтобы не падало)
echo -e "\n${GREEN}Installing base system...${RESET}"
pacstrap -K /mnt base base-devel linux-zen linux-firmware intel-ucode btrfs-progs \
networkmanager zsh git sudo terminus-font xorg-server xorg-xinit \
bspwm polybar sxhkd neovim alacritty feh rofi

genfstab -U /mnt >> /mnt/etc/fstab

# Настройка внутри chroot
arch-chroot /mnt /bin/bash <<EOF
ln -sf /usr/share/zoneinfo/Europe/Moscow /etc/localtime
hwclock --systohc
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
echo "ru_RU.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=ru_RU.UTF-8" > /etc/locale.conf
echo "$HOSTNAME" > /etc/hostname

# Пароли (упростил для примера, смени потом через passwd)
echo "root:123" | chpasswd
useradd -m -G wheel -s /bin/zsh $USERNAME
echo "$USERNAME:123" | chpasswd
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# Загрузчик
bootctl --path=/boot install
UUID=\$(blkid -s UUID -o value $PART_ROOT)
echo "default arch.conf" > /boot/loader/loader.conf
cat <<CONF > /boot/loader/entries/arch.conf
title   Arch Linux
linux   /vmlinuz-linux-zen
initrd  /intel-ucode.img
initrd  /initramfs-linux-zen.img
options root=UUID=\$UUID rootflags=subvol=@ rw
CONF

# ПОПЫТКА УСТАНОВИТЬ NVIDIA ВНУТРИ (если не выйдет - не страшно, система загрузится)
pacman -S --noconfirm nvidia nvidia-utils || echo "Nvidia install failed, will do it manually later"

systemctl enable NetworkManager
EOF

echo -e "\n${GREEN}Installation complete! Restarting...${RESET}"
