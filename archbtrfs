#!/bin/bash
# Оптимизированный установщик для Dell Latitude 5580 (i7-7820HQ / NVIDIA 940MX)
set -e
clear

GREEN="\e[32m"
RED="\e[31m"
YELLOW="\e[33m"
RESET="\e[0m"

echo -e "${YELLOW}Подготовка установки Arch Linux (UEFI + Btrfs + bspwm)${RESET}"

# [span_7](start_span)Проверка интернета[span_7](end_span)
ping -q -c 1 archlinux.org > /dev/null || { echo -e "${RED}Нет сети!${RESET}"; exit 1; }

# [span_8](start_span)Настройка времени[span_8](end_span)
timedatectl set-ntp true

# [span_9](start_span)Выбор диска[span_9](end_span)
echo -e "\n${GREEN}Доступные диски:${RESET}"
lsblk -dpno NAME,SIZE | grep -v "boot"
read -p "Введите имя диска (напр. /dev/sda): " DISK

# [span_10](start_span)Данные пользователя[span_10](end_span)
read -p "Имя хоста (компьютера): " HOSTNAME
read -p "Имя пользователя: " USERNAME
read -s -p "Пароль root: " ROOT_PASSWORD; echo
read -s -p "Пароль пользователя: " USER_PASSWORD; echo

# [span_11](start_span)Разметка (GPT/UEFI)[span_11](end_span)
sgdisk --zap-all $DISK
sgdisk -n 1:0:+512M -t 1:ef00 $DISK # EFI
sgdisk -n 2:0:0 -t 2:8300 $DISK     # Root
PART_EFI="${DISK}1"
PART_ROOT="${DISK}2"

# [span_12](start_span)Форматирование[span_12](end_span)
mkfs.fat -F32 $PART_EFI
mkfs.btrfs -f -L ArchLinux $PART_ROOT

# [span_13](start_span)Btrfs Subvolumes (Оптимизация под SSD)[span_13](end_span)
mount $PART_ROOT /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@snapshots
btrfs subvolume create /mnt/@var_log
umount /mnt

# [span_14](start_span)Монтирование с оптимизацией (zstd, ssd)[span_14](end_span)
BTRFS_OPTS="noatime,compress=zstd:3,ssd,discard=async,space_cache=v2"
mount -o subvol=@,$BTRFS_OPTS $PART_ROOT /mnt
mkdir -p /mnt/{boot,home,.snapshots,var/log}
mount -o subvol=@home,$BTRFS_OPTS $PART_ROOT /mnt/home
mount -o subvol=@snapshots,$BTRFS_OPTS $PART_ROOT /mnt/.snapshots
mount -o subvol=@var_log,$BTRFS_OPTS $PART_ROOT /mnt/var/log
mount $PART_EFI /mnt/boot

# [span_15](start_span)Установка базы + Драйверы Dell (Intel/Nvidia)[span_15](end_span)
echo -e "${GREEN}Установка пакетов...${RESET}"
pacstrap -K /mnt base base-devel linux-zen linux-firmware btrfs-progs \
intel-ucode networkmanager sudo git zsh neovim \
xorg-server xorg-xinit nvidia nvidia-utils lib32-nvidia-utils \
libva-intel-driver mesa-utils bspwm sxhkd polybar alacritty feh rofi

# [span_16](start_span)Генерация fstab[span_16](end_span)
genfstab -U /mnt >> /mnt/etc/fstab

# [span_17](start_span)Настройка внутри chroot[span_17](end_span)
arch-chroot /mnt /bin/bash <<EOF
ln -sf /usr/share/zoneinfo/Europe/Moscow /etc/localtime
hwclock --systohc
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
echo "ru_RU.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=ru_RU.UTF-8" > /etc/locale.conf
echo "$HOSTNAME" > /etc/hostname

# Настройка паролей
echo "root:$ROOT_PASSWORD" | chpasswd
useradd -m -G wheel,video,audio -s /bin/zsh $USERNAME
echo "$USERNAME:$USER_PASSWORD" | chpasswd
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# Установка загрузчика systemd-boot (быстрее Grub на EFI)
bootctl --path=/boot install
UUID=\$(blkid -s UUID -o value $PART_ROOT)
echo "default arch.conf" > /boot/loader/loader.conf
echo "timeout 3" >> /boot/loader/loader.conf

cat <<CONF > /boot/loader/entries/arch.conf
title   Arch Linux (Zen)
linux   /vmlinuz-linux-zen
initrd  /intel-ucode.img
initrd  /initramfs-linux-zen.img
options root=UUID=\$UUID rw rootflags=subvol=@ nvidia-drm.modeset=1
CONF

systemctl enable NetworkManager
EOF

[span_18](start_span)echo -e "${GREEN}Установка завершена! Перезагрузитесь.${RESET}"[span_18](end_span)
